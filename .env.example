# Worker service URL (for triggering triage from webhook)
# On Railway, use the internal URL: http://worker.railway.internal:3001
WORKER_URL=http://localhost:3001

# Halo Webhook Authentication
HALO_WEBHOOK_USERNAME=triageit
HALO_WEBHOOK_PASSWORD=

# Halo PSA (stored in DB, these are for initial setup only)
# HALO_BASE_URL=
# HALO_CLIENT_ID=
# HALO_CLIENT_SECRET=
# HALO_TENANT=

# Google Custom Search (for agent web research)
GOOGLE_SEARCH_API_KEY=
