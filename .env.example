# Anthropic
ANTHROPIC_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ScreenIT (separate recruiting data project; staff SSO still uses the Supabase vars above)
NEXT_PUBLIC_SCREENIT_SUPABASE_URL=
NEXT_PUBLIC_SCREENIT_SUPABASE_ANON_KEY=
SCREENIT_SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SCREENIT_SSO_DOMAIN=gamma.tech
SCREENIT_DEMO_MODE=false
SCREENIT_REALTIME_MODEL=gpt-realtime
SCREENIT_REALTIME_VOICE=marin
SCREENIT_REPORT_MODEL=gpt-5-mini

# Redis (Railway auto-injects REDIS_URL)
REDIS_URL=redis://localhost:6379

# Worker service URL (for triggering triage from webhook)
# On Railway, use the internal URL: http://worker.railway.internal:3001
WORKER_URL=http://localhost:3001

# Shared secret sent by the web app to protected worker endpoints.
# Set the same value on both the web and worker Railway services.
WORKER_SHARED_SECRET=

# FollowIT SOP service
# Use the public Railway URL here so TriageIT can link to the separate service.
NEXT_PUBLIC_FOLLOWIT_URL=http://localhost:3001
FOLLOWIT_PUBLIC_URL=http://localhost:3001
FOLLOWIT_DATA_DIR=.followit-data
FOLLOWIT_ADMIN_USER=admin
FOLLOWIT_ADMIN_PASSWORD=

# Halo Webhook Authentication
HALO_WEBHOOK_USERNAME=triageit
HALO_WEBHOOK_PASSWORD=

# Halo PSA (stored in DB, these are for initial setup only)
# HALO_BASE_URL=
# HALO_CLIENT_ID=
# HALO_CLIENT_SECRET=
# HALO_TENANT=

# Google Custom Search (for agent web research)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
