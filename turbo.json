{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_SCREENIT_SUPABASE_URL",
    "NEXT_PUBLIC_SCREENIT_SUPABASE_ANON_KEY",
    "SCREENIT_DEMO_MODE",
    "SCREENIT_REALTIME_MODEL",
    "SCREENIT_REALTIME_VOICE",
    "SCREENIT_REPORT_MODEL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
