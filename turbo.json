{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_SCREENIT_SUPABASE_URL",
    "NEXT_PUBLIC_SCREENIT_SUPABASE_ANON_KEY",
    "SCREENIT_SUPABASE_SERVICE_ROLE_KEY",
    "OPENAI_API_KEY",
    "SCREENIT_ADMIN_EMAIL",
    "SCREENIT_ADMIN_PASSWORD_HASH",
    "SCREENIT_AUTH_SECRET",
    "SCREENIT_DEMO_MODE",
    "SCREENIT_REALTIME_MODEL",
    "SCREENIT_REALTIME_VOICE",
    "SCREENIT_VAD_MODE",
    "SCREENIT_VAD_EAGERNESS",
    "SCREENIT_REPORT_MODEL",
    "SCREENIT_RESUME_MODEL",
    "WORKER_URL",
    "WORKER_SHARED_SECRET",
    "TRIAGEIT_WORKER_SECRET",
    "SCREENIT_BASE_URL",
    "SCREENIT_VAD_THRESHOLD",
    "SCREENIT_VAD_SILENCE_MS",
    "SCREENIT_VAD_PREFIX_MS",
    "SCREENIT_BARGE_IN_MIN_MS"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
