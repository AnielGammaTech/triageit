{
  "name": "triageit",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "dev:web": "turbo dev --filter=web",
    "dev:worker": "turbo dev --filter=worker",
    "dev:followit": "turbo dev --filter=followit",
    "build:web": "turbo build --filter=web",
    "build:worker": "turbo build --filter=worker",
    "build:followit": "turbo build --filter=followit"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
