{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npx turbo build --filter=gtools"
  },
  "deploy": {
    "startCommand": "npm run start --workspace=gtools",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
