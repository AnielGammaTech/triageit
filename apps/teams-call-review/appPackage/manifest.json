          "scopes": [
            "personal"
          ],
          "commands": [
            {
              "title": "register",
              "description": "Enable private unmatched-call review cards"
            },
            {
              "title": "help",
              "description": "Show the available call-review actions"
            }
          ]
        }
      ]
    }
  ],
  "permissions": [
    "identity"
